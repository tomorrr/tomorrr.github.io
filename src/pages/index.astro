---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import StarField from "../components/StarField";
import { getPublishedPosts } from "../utils/posts";

const posts = await getPublishedPosts();
---

<BaseLayout title="My Blog" description="个人博客 — 记录思考与创造">
  <StarField client:load />

  <!-- Hero -->
  <section class="text-center mb-20 pt-8">
    <div class="w-24 h-24 rounded-full mx-auto mb-6 bg-aurora-400/10 border-2 border-aurora-400/20 flex items-center justify-center">
      <span class="text-4xl">👋</span>
    </div>
    <h1 class="text-5xl font-bold text-text-primary mb-4">
      Hi, 我是 <span class="text-gradient">[你的名字]</span>
    </h1>
    <p class="text-text-muted text-lg max-w-md mx-auto mb-6">
      前端开发者 / 写点东西 / 做些项目
    </p>
    <div class="flex justify-center gap-8 text-sm">
      <span class="text-aurora-300">
        <span class="text-2xl font-bold">{posts.length}</span>
        <span class="text-text-muted ml-1">篇文章</span>
      </span>
      <span class="text-text-muted">·</span>
      <a href="/projects" class="text-aurora-300 hover:text-aurora-200 transition-colors">项目</a>
      <span class="text-text-muted">·</span>
      <a href="/about" class="text-aurora-300 hover:text-aurora-200 transition-colors">关于</a>
      <span class="text-text-muted">·</span>
      <a href="/rss.xml" class="text-aurora-300 hover:text-aurora-200 transition-colors">RSS</a>
    </div>
  </section>

  <!-- Post list -->
  <section>
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="text-2xl font-bold text-text-primary">最新文章</h2>
      {posts.length > 6 && (
        <a href="/archive" class="text-aurora-300 text-sm hover:text-aurora-200 transition-colors">
          查看全部 &rarr;
        </a>
      )}
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.slice(0, 6).map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
