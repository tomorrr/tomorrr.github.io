---
import BaseLayout from "../layouts/BaseLayout.astro";
import StarField from "../components/StarField";
import PostList from "../components/PostList";
import { getPublishedPosts } from "../utils/posts";

const posts = await getPublishedPosts();
const postData = posts.map((p) => ({
  slug: p.slug,
  data: { ...p.data, date: p.data.date.toISOString().slice(0, 10) },
}));
---

<BaseLayout title="My Blog" description="个人博客 — 记录思考与创造">
  <StarField client:load />

  <!-- Hero -->
  <section class="text-center mb-12 pt-8">
    <div class="w-28 h-28 rounded-full mx-auto mb-6 bg-aurora-400/10 border-2 border-aurora-400/20 flex items-center justify-center">
      <span class="text-4xl">👋</span>
    </div>
    <h1 class="text-5xl font-bold text-text-primary mb-4">
      Hi, 我是 <span class="text-gradient">木木</span>
    </h1>
    <p class="text-text-muted text-lg max-w-lg mx-auto leading-relaxed">
      欢迎来到我的博客<br/>
      代码、文字、想法 — 这里是我和世界对话的地方。
    </p>
  </section>

  <PostList posts={postData} client:load />
</BaseLayout>
