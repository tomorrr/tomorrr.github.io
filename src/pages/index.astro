---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import StarField from "../components/StarField";
import { getPublishedPosts } from "../utils/posts";

const posts = await getPublishedPosts();
---

<BaseLayout title="My Blog" description="个人博客 — 记录思考与创造">
  <StarField client:load />

  <!-- Hero -->
  <section class="mb-20 pt-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-center">
      <!-- Left: Avatar + name -->
      <div class="flex-shrink-0 text-center lg:text-left">
        <div class="w-28 h-28 rounded-full mx-auto lg:mx-0 mb-5 bg-aurora-400/10 border-2 border-aurora-400/20 flex items-center justify-center">
          <span class="text-4xl">👋</span>
        </div>
        <h1 class="text-5xl font-bold text-text-primary mb-2">
          <span class="text-gradient">Linn</span>
        </h1>
        <p class="text-text-muted text-lg">
          开发者 · 写作者 · 创造者
        </p>
      </div>

      <!-- Right: Intro card -->
      <div class="flex-1 glass p-6 lg:p-8 max-w-2xl">
        <p class="text-text-body text-base leading-relaxed mb-4">
          嘿，欢迎来到我的数字花园。我在这里记录技术探索、项目心得和偶尔的胡思乱想。我相信分享是学习的最好方式，也希望这些内容能对你有所启发。
        </p>
        <div class="flex items-center gap-6 text-sm pt-3 border-t border-white/5">
          <a href="/posts/hello-world" class="text-aurora-300 hover:text-aurora-200 transition-colors">
            最近文章 &rarr;
          </a>
          <a href="/projects" class="text-aurora-300 hover:text-aurora-200 transition-colors">
            我的项目 &rarr;
          </a>
          <a href="/about" class="text-aurora-300 hover:text-aurora-200 transition-colors">
            了解更多 &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Post list -->
  <section>
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="text-2xl font-bold text-text-primary">最新文章</h2>
      {posts.length > 6 && (
        <a href="/archive" class="text-aurora-300 text-sm hover:text-aurora-200 transition-colors">
          查看全部 &rarr;
        </a>
      )}
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.slice(0, 6).map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
