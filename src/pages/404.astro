---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — 页面不存在" description="找不到该页面">
  <div class="text-center py-20">
    <h1 class="text-6xl font-bold text-gradient mb-4">404</h1>
    <p class="text-text-muted mb-8">抱歉，这个页面不存在。</p>
    <a href="/" class="text-aurora-300 hover:text-aurora-200 transition-colors text-sm">
      &larr; 返回首页
    </a>
  </div>
</BaseLayout>
