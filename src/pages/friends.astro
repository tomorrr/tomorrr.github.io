---
import BaseLayout from "../layouts/BaseLayout.astro";

const friends = [
  {
    name: "阮一峰的网络日志",
    url: "https://www.ruanyifeng.com/blog/",
    description: "科技爱好者周刊，每周五更新，质量稳定了十几年。"
  },
  {
    name: "酷壳 - CoolShell",
    url: "https://www.coolshell.cn/",
    description: "技术人必读，冷静、深度、不跟风。"
  },
  {
    name: "张鑫旭的博客",
    url: "https://www.zhangxinxu.com/",
    description: "CSS 大神，前端细节讲得透透的。"
  },
  {
    name: "程序员的喵",
    url: "https://catcoding.me/",
    description: "写代码、养猫、思考人生。"
  },
  {
    name: "云风的 BLOG",
    url: "https://blog.codingnow.com/",
    description: "游戏开发前辈，技术功底深厚。"
  },
  {
    name: "鸟窝",
    url: "https://colobu.com/",
    description: "Go 语言技术博客，内容扎实。"
  },
];
---

<BaseLayout title="友链" description="朋友们">
  <h1 class="text-3xl font-bold text-text-primary mb-2">友链</h1>
  <p class="text-text-muted mb-8">一些值得关注的朋友和博客</p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {friends.map((f) => (
      <a href={f.url} target="_blank" rel="noopener noreferrer" class="glass-card block p-5 no-underline group">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h3 class="text-text-primary font-bold text-sm group-hover:text-aurora-200 transition-colors">
              {f.name}
            </h3>
            <p class="text-text-muted text-xs mt-1.5 leading-relaxed">{f.description}</p>
          </div>
          <span class="text-aurora-300 text-lg flex-shrink-0 mt-0.5">&rarr;</span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
